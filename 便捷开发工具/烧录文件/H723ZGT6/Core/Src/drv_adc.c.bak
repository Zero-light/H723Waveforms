/*
 * drv_adc.c
 * ADC driver implementation using BSP_ADC API.
 */
#include "drv_adc.h"
#include "bsp_adc.h"
#include "bsp.h"
#include "protocol.h"
#include "board_config.h"
#include <string.h>
#include <stdio.h>

/* Debug option: set to 1 to print GPIOA registers once at first poll */
#define DRV_ADC_DEBUG_GPIO      1

/* Test option: set to 1 to use single-conversion mode instead of continuous.
 * This helps rule out stale-sample issues. */
#define DRV_ADC_TEST_SINGLE_CONV 0

static uint16_t s_sampleBuf[DRV_ADC_BATCH_SIZE];
static uint8_t  s_bufIdx;
static DrvAdcConfig_t s_config = {0};
static volatile bool s_running = false;
static uint16_t s_seqId = 0;
static uint8_t  s_numEnabled = 0;
static ProtoFrame_t s_txFrame;
static BspAdcHandle_t s_adcHandle = NULL;

/* Map logical channel index to board-specific ADC channel constant. */
static const BspAdcChannel_t s_channelMap[DRV_ADC_MAX_CHANNELS] = {
    BSP_ADC_CH0_CHANNEL,    /* PA6 -> ADC1_IN3 */
    BSP_ADC_CH1_CHANNEL,    /* PA7 -> ADC1_IN7 */
};

void DRV_ADC_Init(void)
{
    memset(s_sampleBuf, 0, sizeof(s_sampleBuf));
    memset((void *)&s_config, 0, sizeof(s_config));
    s_running = false;
    s_bufIdx = 0;
    s_seqId = 0;
    s_numEnabled = 0;
    memset(&s_txFrame, 0, sizeof(s_txFrame));
    s_txFrame.cmd = CMD_ADC_DATA;
    s_adcHandle = NULL;
}

bool DRV_ADC_Configure(const DrvAdcConfig_t *cfg)
{
    if (cfg == NULL) return false;

    if (s_running) DRV_ADC_Stop();

    /* PA6 is always enabled; mask out any illegal bits. */
    s_config = *cfg;
    s_config.ch_mask = DRV_ADC_MASK_PA6;
    if (cfg->ch_mask & DRV_ADC_MASK_PA7) {
        s_config.ch_mask |= DRV_ADC_MASK_PA7;
    }

    s_numEnabled = 1;  /* PA6 */
    if (s_config.ch_mask & DRV_ADC_MASK_PA7) {
        s_numEnabled = 2;
    }

    BspAdcChannel_t channels[DRV_ADC_MAX_CHANNELS];
    uint8_t rank = 0;
    channels[rank++] = s_channelMap[0];                 /* PA6 always first */
    if (s_config.ch_mask & DRV_ADC_MASK_PA7) {
        channels[rank++] = s_channelMap[1];             /* PA7 optional */
    }

    BspAdcConfig_t bspCfg = {
        .resolution_bits = 12,
        .sample_time = ADC_SAMPLETIME_810CYCLES_5,
        .continuous = (DRV_ADC_TEST_SINGLE_CONV == 0),
        .num_channels = s_numEnabled,
        .channels = channels,
    };

    if (!BSP_ADC_Init(&s_adcHandle, &bspCfg)) return false;
    return true;
}

bool DRV_ADC_Start(void)
{
    if (s_running || s_config.ch_mask == 0) return false;
    s_seqId = 0;
    s_bufIdx = 0;
    if (!BSP_ADC_Start(s_adcHandle)) return false;
    s_running = true;
    return true;
}

void DRV_ADC_Stop(void)
{
    if (!s_running) return;
    BSP_ADC_Stop(s_adcHandle);
    s_running = false;
}

bool DRV_ADC_IsRunning(void)
{
    return s_running;
}

void DRV_ADC_Poll(void)
{
    if (!s_running || s_numEnabled == 0) return;

#if DRV_ADC_DEBUG_GPIO
    {
        static bool s_gpioReported = false;
        if (!s_gpioReported) {
            char msg[128];
            snprintf(msg, sizeof(msg),
                     "[ADC DBG] GPIOA MODER=0x%08X AFR0=0x%08X CH=%u\r\n",
                     (unsigned)BSP_GPIO_ReadModer(BSP_ADC_CH0_PIN_PORT),
                     (unsigned)BSP_GPIO_ReadAfr(BSP_ADC_CH0_PIN_PORT, 0),
                     (unsigned)s_numEnabled);
            BSP_USB_Transmit((const uint8_t *)msg, (uint16_t)strlen(msg));
            s_gpioReported = true;
        }
    }
#endif

#if DRV_ADC_TEST_SINGLE_CONV
    /* Single-conversion sequence: start once, poll each channel, then stop.
     * This avoids stale samples from continuous mode. */
    if (!BSP_ADC_Start(s_adcHandle)) return;
    for (uint8_t i = 0; i < s_numEnabled; i++) {
        if (!BSP_ADC_PollForConversion(s_adcHandle, 100)) {
            BSP_ADC_Stop(s_adcHandle);
            return;
        }
        s_sampleBuf[s_bufIdx++] = (uint16_t)BSP_ADC_ReadValue(s_adcHandle);
    }
    BSP_ADC_Stop(s_adcHandle);
#else
    for (uint8_t i = 0; i < s_numEnabled; i++) {
        if (!BSP_ADC_PollForConversion(s_adcHandle, 100)) return;
        s_sampleBuf[s_bufIdx++] = (uint16_t)BSP_ADC_ReadValue(s_adcHandle);
    }
#endif

    if (s_bufIdx >= DRV_ADC_BATCH_SIZE) {
        uint16_t payloadLen = 4 + (s_bufIdx * sizeof(uint16_t));
        s_txFrame.len = payloadLen;
        s_txFrame.payload[0] = (uint8_t)(s_seqId & 0xFF);
        s_txFrame.payload[1] = (uint8_t)((s_seqId >> 8) & 0xFF);
        s_txFrame.payload[2] = s_config.ch_mask;
        s_txFrame.payload[3] = s_config.mode;
        memcpy(&s_txFrame.payload[4], s_sampleBuf, s_bufIdx * sizeof(uint16_t));

        if (PROTO_SendFrame(&s_txFrame)) {
            s_seqId++;
        }
        s_bufIdx = 0;
    }
}
